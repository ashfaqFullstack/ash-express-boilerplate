# App
NODE_ENV=development
PORT=8000

# PostgreSQL — replace with your actual connection string
# Local:   postgresql://postgres:password@localhost:5432/your_db
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Neon:    postgresql://[user]:[pass]@[host]/[db]?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/ash_express_db

# JWT
JWT_SECRET=your_super_secret_key
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
